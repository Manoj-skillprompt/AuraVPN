{
  "name": "vpn",
  "version": "1.0.0",
  "description": "Premium High-Speed VPN Client",
  "author": "Manoj",
  "homepage": "https://github.com/Manoj-skillprompt/AuraVPN",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "next build && electron-builder",
    "dist:linux": "next build && electron-builder --linux",
    "dist:win": "next build && electron-builder --win"
  },
  "build": {
    "appId": "com.auravpn.app",
    "productName": "AuraVPN",
    "publish": [
      {
        "provider": "github",
        "owner": "Manoj-skillprompt",
        "repo": "AuraVPN"
      }
    ],
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json",
      "configs/**/*",
      "public/**/*"
    ],
    "linux": {
      "maintainer": "Manoj Chaudhary",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png"
    }
  },
  "dependencies": {
    "electron-serve": "^1.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5"
  }
}
